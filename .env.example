# ── AlpacaTrader environment template ─────────────────────────────────────────
# Copy this file to `.env` and fill in your own values, then:
#   chmod 600 .env
#
# `.env` is gitignored. Never commit real credentials.

# ── Flask session secret (auto-generated on first boot if absent) ─────────────
# SECRET_KEY='generated-on-first-run-32-byte-hex'

# ── Anthropic (optional — only needed for the Bull/Bear debate gate) ──────────
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# ── Polygon (optional — used by some backtest scripts) ────────────────────────
# POLYGON_API_KEY=xxxx

# ── Finnhub (optional — news pre-filter, falls back to yfinance if absent) ────
# FINNHUB_API_KEY=xxxx

# ── Alpaca paper-trading credentials (REQUIRED) ───────────────────────────────
# Get these from https://app.alpaca.markets → Paper Trading → API Keys.
#
# Only these three canonical names are needed. The server uses them for
# both browser login + headless auto-login + the screener executor.
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxx
ALPACA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true   # set to "false" to use a live account — DANGEROUS

# ── Legacy env var names (still honoured as fallback) ─────────────────────────
# scripts/credentials.py also reads ALPACA_AUTO_KEY/SECRET/PAPER and the older
# ALPACA_SECRET_KEY if the canonical names above aren't set. New installs
# should only use the canonical names.
